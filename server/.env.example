# ─── 필수 설정 ────────────────────────────────────────────
ADMIN_CODE=여기에_관리자_비밀번호_입력
JWT_SECRET=여기에_랜덤_32바이트_이상_문자열_입력
AUTH_CODE_PEPPER=인증번호_HMAC용_별도_랜덤_32바이트_문자열
PORT=3000
STORE_NAME=따뜻한 떡집
STORE_PHONE=031-000-0000
STORE_HOURS=09:00 - 19:00
STORE_ADDRESS=경기도 화성시 소재
STORE_PARKING=건물 내 주차 공간 이용 가능
STORE_URL=https://smartstore.naver.com/

# ─── 클라우드 배포 설정 ───────────────────────────────────
# DB 영구 저장 경로 (Railway 볼륨 마운트 시: /data/tteokjip.db)
# DB_PATH=/data/tteokjip.db
# BACKUP_DIR=/data/backups
# BACKUP_RETENTION=14
# CORS 허용 도메인 (배포 후 실제 URL로 교체)
# ALLOWED_ORIGIN=https://your-app.railway.app
# 운영 환경에서는 아래 핵심 값이 없거나 예시 값이면 서버가 시작되지 않습니다.
# NODE_ENV=production

# ─── 알림 설정 ────────────────────────────────────────────
# NOTIFICATION_MODE: none(비활성) | sms | kakao
NOTIFICATION_MODE=none
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
KAKAO_PLUS_FRIEND_ID=
KAKAO_TEMPLATE_ORDER=
KAKAO_TEMPLATE_READY=
KAKAO_TEMPLATE_REMIND=

# 운영 회원가입의 휴대폰 인증은 위 SOLAPI 3개 값이 모두 필요합니다.
# 미설정 상태의 production 서버는 개발용 인증번호를 노출하지 않고 503을 반환합니다.

# ─── 비밀번호 재설정 이메일(Resend) ───────────────────────
RESEND_API_KEY=
PASSWORD_RESET_FROM=따뜻한 떡집 <no-reply@your-domain.com>

# ─── 소셜 로그인 ──────────────────────────────────────────
# 콜백: {PUBLIC_BASE_URL}/api/auth/social/{google|kakao|naver}/callback
PUBLIC_BASE_URL=https://your-domain.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ─── 토스페이먼츠 ─────────────────────────────────────────
# 샌드박스(테스트): https://developers.tosspayments.com 에서 무료 발급
# 운영(실제결제): 사업자 등록 후 심사 통과 필요
TOSS_CLIENT_KEY=your-toss-client-key
TOSS_SECRET_KEY=your-toss-secret-key

# ─── 로컬 포트폴리오 도구(선택) ─────────────────────────
# demo:seed 기본값을 바꾸고 싶을 때만 설정합니다. 운영 환경에서는 실행이 차단됩니다.
# DEMO_USERNAME=portfolio_demo
# DEMO_EMAIL=demo@tteokjip.local
# DEMO_PASSWORD=Demo123!
# ALLOW_PORTFOLIO_SEED=true

# 실제 결제 API 없이 결제 흐름을 검증하는 로컬·자동 테스트 전용 옵션
# 운영 환경에서는 사용하지 않습니다.
# TOSS_MOCK_MODE=false

# portfolio:capture 설정. 서버 주소와 설치된 Chrome 실행 파일 경로를 지정합니다.
# CAPTURE_BASE_URL=http://localhost:3000
# CHROME_PATH=/path/to/chrome
